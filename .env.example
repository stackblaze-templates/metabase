# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# PostgreSQL credentials — choose strong, unique passwords for production
MB_DB_PASS=change_me_strong_password
POSTGRES_PASSWORD=change_me_strong_password

# Optional: override database name / user (defaults shown)
# MB_DB_DBNAME=metabase
# MB_DB_USER=metabase
# POSTGRES_DB=metabase
# POSTGRES_USER=metabase
